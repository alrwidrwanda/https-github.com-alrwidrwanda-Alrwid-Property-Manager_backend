# Server
PORT=5000
NODE_ENV=development

# MongoDB - replace with your connection string
# Format: mongodb://host:port/database-name (local) or mongodb+srv://user:pass@cluster.mongodb.net/database-name?options (Atlas)
MONGODB_URI=mongodb://localhost:27017/alrwid-property-manager

# Optional: Frontend URL for CORS (comma-separated for multiple)
# CLIENT_ORIGIN=http://localhost:5173
